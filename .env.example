# Existing Flask webhook variables
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
KOBO_TOKEN=your_kobo_token
GOOGLE_CREDS_JSON={"type":"service_account",...}

# Supabase integration variables
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Next.js API -> Supabase Edge Function
TELEGRAM_EDGE_FUNCTION_URL=https://your-project-ref.functions.supabase.co/send-telegram
TELEGRAM_EDGE_FUNCTION_SECRET=your_function_secret

# Supabase Edge Function secrets
FUNCTION_SECRET=your_function_secret
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
